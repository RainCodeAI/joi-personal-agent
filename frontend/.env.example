# Default (recommended): leave NEXT_PUBLIC_API_BASE_URL unset. The frontend then
# talks to the backend through its same-origin /api/backend proxy, which injects
# the token server-side from JOI_API_TOKEN — the token never ships in the browser.
JOI_API_TOKEN=change-me

# Direct mode (desktop shell / Docker): set an absolute backend URL to bypass the
# proxy and call the backend directly. In this mode the token IS exposed to the
# browser via NEXT_PUBLIC_JOI_API_TOKEN.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_JOI_API_TOKEN=change-me
