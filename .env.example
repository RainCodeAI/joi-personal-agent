APP_ENV=dev
OLLAMA_HOST=http://127.0.0.1:11434
# Local Ollama model tag (must be pulled in Ollama, e.g. `ollama pull llama3.2`)
MODEL_OLLAMA=llama3.2
# OpenAI-side chat model
MODEL_CHAT=gpt-4o-mini
# Use validated LLM tool proposals for likely tool requests; invalid output falls back.
TOOL_PLANNING_ENABLED=true
# STT engine for voice: "whisper" (local, on-device) or "google"
STT_ENGINE=whisper
DB_PATH=./data/agent.db
CHROMA_PATH=./data/index
CHROMA_SERVER_HOST=
CHROMA_SERVER_PORT=8001
AIRGAP=false
JOI_API_TOKEN=change-me-to-a-long-random-token
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8501
FILE_INGEST_ROOTS=./data/ingest
FILE_INGEST_MAX_FILES=500
FILE_INGEST_MAX_FILE_BYTES=1000000
FILE_INGEST_MAX_DEPTH=6
# Google OAuth (read-only scopes)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
# Optional: PASSPHRASE for vault
VAULT_PASSPHRASE=
# Telegram bridge (remote chat surface). Disabled until a token is set; only
# allowlisted numeric user IDs may talk to it. Never exposes the Joi API.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_API_BASE_URL=http://127.0.0.1:8000
# TELEGRAM_JOI_API_TOKEN falls back to JOI_API_TOKEN when unset.
TELEGRAM_JOI_API_TOKEN=
# Proactive delivery: push gated initiatives to Telegram while you're away.
# Opt-in; only the listed initiative types leave the laptop.
TELEGRAM_PROACTIVE_ENABLED=false
TELEGRAM_PROACTIVE_TYPES=daily_greeting,return_after_absence,late_night_checkin,calendar_heads_up
TELEGRAM_OUTBOX_POLL_SECONDS=60
