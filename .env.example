APP_ENV=dev
OLLAMA_HOST=http://127.0.0.1:11434
# Local Ollama model tag (must be pulled in Ollama, e.g. `ollama pull llama3.2`)
MODEL_OLLAMA=llama3.2
# OpenAI-side chat model
MODEL_CHAT=gpt-4o-mini
# Use validated LLM tool proposals for likely tool requests; invalid output falls back.
TOOL_PLANNING_ENABLED=true
# STT engine for voice: "whisper" (local, on-device) or "google"
STT_ENGINE=whisper
DB_PATH=./data/agent.db
CHROMA_PATH=./data/index
CHROMA_SERVER_HOST=
CHROMA_SERVER_PORT=8001
AIRGAP=false
JOI_API_TOKEN=change-me-to-a-long-random-token
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8501
FILE_INGEST_ROOTS=./data/ingest
FILE_INGEST_MAX_FILES=500
FILE_INGEST_MAX_FILE_BYTES=1000000
FILE_INGEST_MAX_DEPTH=6
# Google OAuth (read-only scopes)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
# Optional: PASSPHRASE for vault
VAULT_PASSPHRASE=
